<!DOCTYPE html>
<html lang="en">

<body>
    <%- include('partials/search.ejs') %>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Phone Number</th>
                <th>Email</th>
                <th>Address</th>
                <th>Date of Birth</th>
                <th>Gender</th>
                <th>City</th>
            </tr>
        </thead>
        <tbody>
            <% for( let i = 0; i < pageData.length; i++ ) { %>
            <tr>
                <td><%= pageData[i].id %></td>
                <td><%= pageData[i].first_name + ' ' + pageData[i].last_name %></td>
                <td><%= pageData[i].phone %></td>
                <td><%= pageData[i].email %></td>
                <td><%= pageData[i].full_address %></td>
                <td><%= pageData[i].dob %></td>
                <td><%= pageData[i].gender %></td>
                <td><%= pageData[i].city %></td>
            </tr>
            <% } %>
        </tbody>
    </table>
    <%- include('partials/pagination') %>
</body>

</html>