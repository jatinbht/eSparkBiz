<!DOCTYPE html>
<html lang="en">

<body>
    <fieldset>
        <legend>Education Details</legend>

        <form action="/education/save" method="get">
            <table>
                <thead>
                    <tr>
                        <th>Course Name</th>
                        <th>Board/University</th>
                        <th>Passing Year</th>
                        <th>Percentage</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="text" name="course"></td>
                        <td><input type="text" name="board_or_university"></td>
                        <td><input type="number" name="passing_year"></td>
                        <td><input type="number" name="percentage"></td>
                    </tr>
                </tbody>
            </table>
            <input type="submit" value="submit">
        </form>

        <button type="button" onclick="addEducationRow()">Add Education</button>
        <button type="button" onclick="removeRow()">Remove</button>

        <script>
            function addEducationRow() {
                const table = document.querySelector("#educationTable tbody");
                const row = table.rows[0].cloneNode(true);
                row.querySelectorAll("input").forEach(input => input.value = "");
                table.appendChild(row);
            }

            function removeRow() {
                const tbody = document.querySelector('table tbody')
                const lastRow = document.querySelector('table tbody').lastChild
                const rowCount = document.querySelector('table tbody').childElementCount

                if (rowCount > 1) {
                    tbody.removeChild(lastRow)
                }
            }
        </script>
    </fieldset>
</body>

</html>