<!DOCTYPE html>
<html lang="en">

<body>
    <fieldset>
        <legend>Technologies</legend>
        <form action="/technologies/save" method="post">
            <select name="applicantId">
                <% for( let i = 0; i < applicants.length; i++ ) { %>
                <option value="<%= applicants[i].id %>" >
                    <%= applicants[i].id + " " + applicants[i].first_name %>
                </option>
                <% } %>
            </select>
            <a href="/basic-info/create">OR Create new applicant</a>

            <table id="techTable">
                <thead>
                    <tr>
                        <th>Technology</th>
                        <th>Beginner</th>
                        <th>Mediator</th>
                        <th>Expert</th>
                    </tr>
                </thead>
                <tbody>


                    <% for( let i = 0; i < technologiesList.length; i++ ) { %>
                    <tr>
                        <td><%= technologiesList[i] %></td>
                        <% for( let j = 0; j < proficiencyLevels.length; j++ ) { %>
                        <td><input type="radio" name="<%= technologiesList[i] %>" onclick="handleClick()" <% if (technologies[i]) { %> <%= (technologies[i].proficiency === proficiencyLevels[j]) ? 'checked' : '' %> <% } %> value=<%= proficiencyLevels[j] %>>
                        </td>
                        <% } %>
                    </tr>
                    <% } %>
                </tbody>
            </table>
            <input type="submit" value="Submit">
        </form>

    </fieldset>

    <script>
        function handleClick(e) {
            unselectRadioBtn(e)
        }

        function unselectRadioBtn(e) {

        }
    </script>
</body>

</html>