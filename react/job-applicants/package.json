{
  "private": true,
  "scripts": {
    "db:codegen": "npm run db:codegen -w api",
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
